{
	"name": "@ctx-core/iex-graphql",
	"version": "9.2.274",
	"description": "@ctx-core/iex-graphql",
	"keywords": [
		"ctx-core",
		"iex",
		"graphql",
		"apollo"
	],
	"homepage": "https://github.com/ctx-core/iex-graphql#readme",
	"bugs": {
		"url": "https://github.com/ctx-core/iex-graphql/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ctx-core/iex-graphql.git"
	},
	"license": "Apache-2.0",
	"author": {
		"name": "Brian Takita",
		"url": "https://briantakita.me",
		"email": "info+ctx-core-iex-graphql@briantakita.me"
	},
	"type": "module",
	"files": [
		"*.d.ts",
		"*.js",
		"*.json",
		"./Quote_gql",
		"./RefDataSymbol_gql"
	],
	"types": "./index.d.ts",
	"exports": {
		".": "./index.js",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": ":",
		"clean": ":",
		"exec": "$@",
		"prepublishOnly": "bun run clean && bun run build && bun run test && publint && attw --pack --ignore-rules cjs-resolves-to-esm",
		"test": "bun run test:types && bun run test:unit",
		"test:types": "tsc --noEmit",
		"test:unit": "tsx node_modules/uvu/bin.js . '\\.test\\.(ts|js)$'",
		"disable:test:unit:coverage": "c8 bun run test:unit"
	},
	"dependencies": {
		"@ctx-core/graphql": "*",
		"@ctx-core/iex": "*",
		"graphql": "^16.13.1",
		"graphql-tag": "^2.12.6"
	},
	"devDependencies": {
		"c8": "^11.0.0",
		"tsx": "^4.21.0",
		"typescript": "next",
		"uvu": "^0.5.6"
	},
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false
}
